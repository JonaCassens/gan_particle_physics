# HTCondor Submit File — Evaluate all bounded_r generators (v1 and v2)

executable = /home/hep/jcc525/gan_particle_physics/condor/eval_script.sh
arguments  = --run-dir $(run_dir) --pdg $(pdg)

initialdir = /home/hep/jcc525/gan_particle_physics/condor

output = logs/eval_bounded_r_$(ClusterId).$(Process).out
error  = logs/eval_bounded_r_$(ClusterId).$(Process).err
log    = logs/eval_bounded_r_$(ClusterId).$(Process).log

+MaxRuntime = 3600

request_cpus   = 1
request_gpus   = 1
request_memory = 8GB
request_disk   = 8GB

queue run_dir, pdg from (
  bounded_r_electron,       11
  bounded_r_electron_2,     11
  bounded_r_muon,           13
  bounded_r_muon_2,         13
  bounded_r_muon_minus,     -13
  bounded_r_muon_minus_2,   -13
  bounded_r_neutron,        2112
  bounded_r_neutron_2,      2112
  bounded_r_photon,         22
  bounded_r_photon_2,       22
  bounded_r_positron,       -11
  bounded_r_positron_2,     -11
)
